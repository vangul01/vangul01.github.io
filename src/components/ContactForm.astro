---
// Add state for form submission
const { success } = Astro.props;
---

<div id="contact-modal" class="contact-container">
  <div class="contact-box">
    <span class="button-modal-close">&times;</span>
    <h3>Contact Us</h3>
    <br />

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>
          Don't fill this out if you're human: <input name="bot-field" />
        </label>
      </p>

      <div class="form-field">
        <input
          type="text"
          id="contact-first-name"
          name="first-name"
          placeholder=" "
          autocomplete="given-name"
          required
        />
        <label for="contact-first-name">First Name</label>
      </div>

      <div class="form-field">
        <input
          type="text"
          id="contact-last-name"
          name="last-name"
          placeholder=" "
          autocomplete="family-name"
          required
        />
        <label for="contact-last-name">Last Name</label>
      </div>

      <div class="form-field">
        <input
          class="email"
          type="email"
          id="contact-email"
          name="email"
          placeholder=" "
          autocomplete="email"
          required
        />
        <label for="contact-email">Email</label>
      </div>

      <div class="form-field">
        <textarea
          id="contact-message"
          name="message"
          placeholder=" "
          rows="5"
          cols="50"
          required></textarea>
        <label for="contact-message">Message</label>
      </div>

      <br />
      <button class="button button-secondary" type="submit"> Submit </button>

      <div id="success-message" class="hidden">
        Thanks for contacting us! We'll get back to you as soon as possible.
      </div>
    </form>
  </div>
</div>

