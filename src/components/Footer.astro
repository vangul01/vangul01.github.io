---
import { getImage } from "astro:assets";
import { siteNavigation } from "../config/navigation";
import NewsletterForm from "./NewsletterForm.astro";

import plantieFooter from "../assets/images/web/plantie_footer.png";

const currentYear = new Date().getFullYear();
const footerLinks = siteNavigation.footerLinks;

const optimizedPlantie = await getImage({ src: plantieFooter, widths: [600] });
---

<footer
  class="footer"
  style={`--footer-bg-url: url("${optimizedPlantie.src}");`}
>
  <div class="footer-grid">
    <!-- Social Links -->
    <div class="social-section">
      <ul class="social-links">
        {
          footerLinks.social.map(({ name, href, icon }) => (
            <a
              href={href}
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={name}
            >
              <i class={`fa fa-${icon}`} />
            </a>
          ))
        }
      </ul>
    </div>

    <!-- Quick Links -->
    <div class="footer-section">
      <h4 class="footer-title">Links</h4>
      <ul class="link-list">
        {
          footerLinks.quickLinks.map(({ name, href }) => (
            <li>
              <a href={href} class="footer-link">
                {name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Newsletter -->
    <div class="footer-section newsletter">
      <h4 class="footer-title">Stay Updated</h4>
      <p>Subscribe to get special offers and updates!</p>
      <NewsletterForm />
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <p>© {currentYear} VANGULAR. All rights reserved.</p>
  </div>
</footer>
