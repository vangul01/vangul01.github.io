<form
  name="newsletter"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="newsletter-form"
  style="max-width:540px; margin:auto; background:#EFF2F7; border-radius:3px; border:1px solid #C0CCD9; padding:2rem;"
>
  <h4
    class="footer-title"
    style="font-size:2rem; font-weight:700; color:#3C4858; margin-bottom:0.5rem;"
  >
    ✨Newsletter✨
  </h4>
  <p style="font-size:1rem; color:#3C4858; margin-bottom:1rem;">
    Subscribe to our newsletter and stay updated!
  </p>

  <!-- Honeypot field for spam protection -->
  <div style="display:none;">
    <label>
      Don't fill this out if you're human: <input name="bot-field" />
    </label>
  </div>
  <input type="hidden" name="form-name" value="newsletter" />

  <div class="form__entry entry_block" style="margin-bottom:1rem;">
    <input
      class="newsletter-input"
      type="email"
      name="email"
      placeholder="Enter your email"
      aria-label="Email for newsletter"
      autocomplete="email"
      required
      style="width:100%; padding:0.75rem; font-size:1rem; border-radius:3px; border:1px solid #c0ccda;"
    />
  </div>

  <button
    type="submit"
    class="button button-secondary"
    aria-label="Subscribe to newsletter"
    style="width:100%; font-size:1rem; font-weight:700; color:#fff; background:#4c3e57; border:none; border-radius:3px; padding:0.75rem; cursor:pointer;"
  >
    <svg
      class="icon clickable__icon progress-indicator__icon"
      viewBox="0 0 512 512"
      style="vertical-align:middle; margin-right:0.5em; width:1em; height:1em;"
    >
      <path
        d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z"
        fill="#fff"></path>
    </svg>
    SUBSCRIBE
  </button>

  <div
    class="newsletter-declaration"
    style="font-size:0.75rem; color:#687484; margin-top:1rem;"
  >
    <svg
      class="svgIcon-sphere"
      style="width:1.5em; height:1.5em; vertical-align:middle; margin-right:0.5em;"
      viewBox="0 0 63 63"
    >
      <path
        d="M31.54 0l1.05 3.06 3.385-.01-2.735 1.897 1.05 3.042-2.748-1.886-2.738 1.886 1.044-3.05-2.745-1.897h3.393zm13.97 3.019L46.555 6.4l3.384.01-2.743 2.101 1.048 3.387-2.752-2.1-2.752 2.1 1.054-3.382-2.745-2.105h3.385z"
        fill="#0092FF"></path>
    </svg>
    We use Netlify Forms for secure newsletter signup. Your email will only be used
    for updates. See our <a href="/privacy" target="_blank">Privacy Policy</a>.
  </div>
</form>
