---
// make this a dynamic read of sanity data

import vangularLogo from "/src/assets/images/web/logo_transparent.png";
import { siteNavigation } from "../config/navigation";

// Get the current path
const currentPath = Astro.url.pathname;
const links = siteNavigation.headerLinks;
---

<header>
  <nav class="header-nav">
    <div class="logo-container">
      <img src={vangularLogo.src} alt="" />
      <a href={links.logo[0].href} class="header-title header-link">
        {links.logo[0].name}
      </a>
    </div>

    <ul class="nav-links">
      {
        links.mainNav.map(({ name, href }) => (
          <li class="nav-item">
            <a
              href={href}
              id="nav-link"
              class={`header-link ${currentPath === href ? "active" : ""}`}
            >
              {name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="nav-cart-container">
      <a
        href={links.cart[0].href}
        class={`header-link ${currentPath === links.cart[0].href ? "active" : ""}`}
      >
        <i class="fa fa-shopping-cart"></i>
        <span id="cart-icon-count"></span>
      </a>

      <button class="nav-toggle" aria-label="toggle navigation">
        <i class="fa fa-bars"></i>
      </button>
    </div>
  </nav>

  <div class="nav-overlay" aria-hidden="true"></div>
</header>
