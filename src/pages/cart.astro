---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

import { getStripePrices } from "../lib/stripe-client";
import type { CartItem } from "../types/sanity-schema";

import { loadCart } from "../scripts/cart/cart-storage";

const pageTitle = "Cart | VANGULAR";
const keywords = "Cart, Shopping Cart, Checkout";

// Load cart items and fetch their prices
const cartItems = loadCart() as CartItem[];
const priceIds = cartItems.map((item: CartItem) => item.priceId);
const prices = priceIds.length > 0 ? await getStripePrices(priceIds) : {};
---

<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <Header />
  <main>
    <section class="content-container">
      <div class="heading">
        <h3>Your Cart</h3>
      </div>

      <!-- <div class="cart-container">
        <div class="cart-list-container">
          <ul id="cart-items-list"></ul>
          <p id="cart-total-price">Total Amount: $0</p>
        </div>
      </div> -->

      <div class="cart-container">
        <div class="empty-cart-message hidden">
          <p>Your cart is empty</p>
          <a href="/merch" class="button button-primary">Continue Shopping</a>
        </div>

        <div class="cart-content hidden">
          <div class="cart-products-grid cart-headers">
            <div class="cart-titles">Product</div>
            <div class="cart-titles">Quantity</div>
            <div class="cart-titles">Total</div>
          </div>

          {
            cartItems.map((item) => (
              <div class="cart-products-grid" data-product-id={item.priceId}>
                <div class="cart-product-info">
                  <div class="cart-product-image">
                    <img
                      src={item.image?.[0] || "/src/assets/images/web/logo.png"}
                      alt={item.name || "Product Image"}
                      loading="lazy"
                    />
                  </div>
                  <div class="cart-product-text">
                    <p>{item.name}</p>
                    <p>
                      ${(prices[item.priceId]?.amount / 100).toFixed(2)} per
                      item
                    </p>
                  </div>
                </div>

                <div class="cart-product-quantity">
                  <div class="quantity-controls">
                    <button
                      class="quantity-btn minus"
                      aria-label="Decrease quantity"
                    >
                      -
                    </button>
                    <span class="quantity">{item.quantity}</span>
                    <button
                      class="quantity-btn plus"
                      aria-label="Increase quantity"
                    >
                      +
                    </button>
                  </div>
                  <button class="delete-btn" aria-label="Remove item">
                    <i class="fa fa-trash" />
                  </button>
                </div>

                <div class="cart-product-total-price">
                  <p>
                    $
                    {(
                      (prices[item.priceId]?.amount / 100) *
                      item.quantity
                    ).toFixed(2)}
                  </p>
                </div>
              </div>
            ))
          }

          <div class="subtotal-container">
            <h4>
              Subtotal: ${
                cartItems
                  .reduce(
                    (total, item) =>
                      total +
                      (prices[item.priceId]?.amount / 100) * item.quantity,
                    0,
                  )
                  .toFixed(2)
              } USD
            </h4>
            <p>Taxes and shipping calculated at checkout</p>
          </div>

          <div class="cart-buttons">
            <a href="/merch" class="link">Continue Shopping</a>
            <a
              href="/checkout"
              class="button button-primary"
              id="proceed-to-payment"
            >
              Proceed to Checkout
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .subtotal-container {
    text-align: right;
    padding: var(--spacing-md); /* Added padding to align with grid */
    gap: var(--spacing-sm);
    h4 {
      font-size: var(--font-size-lg);
      padding-bottom: var(--spacing-sm);
    }
    p {
      font-size: var(--font-size-base);
    }
  }
  .empty-cart-message {
    text-align: center;
    padding: var(--spacing-2xl) 0;
  }

  .empty-cart-message p {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-xl);
    color: var(--color-text-muted);
  }
  .cart-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: var(--spacing-xl);
  }

  .cart-products-grid {
    display: grid;
    grid-template-columns: 3fr 1fr 1fr;
    gap: var(--spacing-3xl);
    width: 100%;
    align-items: center;
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
    /* border-bottom: var(--border-secondary); */
    font-size: var(--font-size-base);
    /* margin: var(--spacing-md) 0; */
    /* padding: 0 var(--spacing-md); */
    border-bottom: var(--border-tertiary);
  }

  .cart-titles {
    display: grid;
    width: 100%;
    font-weight: bold;
    font-size: var(--font-size-sm);
  }

  .cart-product-info {
    display: flex;
    /* flex-direction: row; */
    align-items: center;
    gap: var(--spacing-xl);
    /* width: cart-container; */
  }

  .cart-product-image {
    /* width: 100px;  */
    width: 100px;
    height: 100px;
    flex-shrink: 0;
  }

  .cart-product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius-sm);
    border: var(--border-tertiary);
  }

  .cart-product-text {
    margin-left: var(--spacing-lg);
    /* text-align: right; */
    flex-grow: 1;
    text-align: left;
  }

  .cart-product-total-price {
    p {
      text-align: center;
    }
  }

  .cart-product-quantity {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    justify-content: center;
    text-align: center;

    p {
      text-align: center;
    }
  }

  .quantity-controls {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    border: var(--border-tertiary);
    border-radius: var(--border-radius-sm);
    padding: var(--spacing-xs);
    font-size: var(--font-size-base);
  }

  .quantity-btn {
    background: none;
    border: none;
    color: var(--color-text-primary);
    width: var(--font-size-lg);
    height: var(--font-size-lg);
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .quantity-btn:hover {
    color: var(--color-text-light);
    background-color: var(--color-button-primary);
    border-radius: var(--border-radius-circle);
  }

  .quantity {
    min-width: var(--font-size-lg);
    text-align: center;
    font-weight: bold;
  }

  .delete-btn {
    background: none;
    border: none;
    color: var(--color-error);
    cursor: pointer;
    transition: all var(--transition-normal);
    padding: var(--spacing-xs);
    font-size: var(--font-size-base);
  }
  /*
  .delete-btn:hover {
    transform: scale(1.1);
  } */

  .cart-buttons {
    display: flex;
    justify-content: space-between; /* Changed from flex-end to space-between */
    align-items: center;
    width: 100%;
    padding: var(--spacing-md); /* Added padding to align with grid */
    /* margin-top: var(--spacing-xl);
    border-top: var(--border-tertiary); */

    .link {
      font-size: var(--font-size-base);

      padding: var(--spacing-sm) var(--spacing-md);
    }
  }

  /* Ensure consistent button sizes */
  .cart-buttons .button,
  .cart-buttons .link {
    min-width: 150px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .cart-products-grid,
    .cart-titles {
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--spacing-md);
    }

    .cart-product-image {
      width: 80px;
      height: 80px;
    }

    .cart-buttons {
      flex-direction: column-reverse;
      gap: var(--spacing-md);
    }

    .cart-buttons .button,
    .cart-buttons .link {
      width: 70%;
    }
  }
</style>

<script>
  function initializeQuantityControls() {
    document.querySelectorAll(".quantity-controls").forEach((control) => {
      const minusBtn = control.querySelector(".minus");
      const plusBtn = control.querySelector(".plus");
      const quantitySpan = control.querySelector(".quantity");

      minusBtn?.addEventListener("click", () => {
        let quantity = parseInt(quantitySpan?.textContent || "0");
        if (quantity > 1) {
          quantity--;
          if (quantitySpan) quantitySpan.textContent = quantity.toString();
          updateCartItem(quantity);
        }
      });

      plusBtn?.addEventListener("click", () => {
        let quantity = parseInt(quantitySpan?.textContent || "0");
        quantity++;
        if (quantitySpan) quantitySpan.textContent = quantity.toString();
        updateCartItem(quantity);
      });
    });

    document.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const cartItem = (e.target as HTMLElement).closest(
          ".cart-products-grid",
        );
        if (cartItem) {
          cartItem.remove();
          updateCart();
        }
      });
    });
  }

  function updateCartItem(quantity: number) {
    // Add your cart update logic here
    console.log("Updated quantity:", quantity);
    updateCart();
  }

  import { loadCart } from "../scripts/cart/cart-storage.js";

  function handleEmptyCart() {
    const emptyMessage = document.querySelector(".empty-cart-message");
    const cartContent = document.querySelector(".cart-content");
    const cart = loadCart();

    if (emptyMessage && cartContent) {
      const isEmpty = cart.length === 0;
      console.log("Cart is empty:", isEmpty, cart.length, cart);

      //   if (isEmpty) {
      //     console.log("Cart is empty for real!");
      //     // Cart is empty
      //     emptyMessage.classList.remove("hidden");
      //     cartContent.classList.add("hidden");
      //   } else {
      //     console.log("Cart is NOT EMPTY!");
      //     // Has items in cart
      //     emptyMessage.classList.add("hidden");
      //     cartContent.classList.remove("hidden");
      //   }

      emptyMessage.classList.toggle("hidden", !isEmpty);
      cartContent.classList.toggle("hidden", isEmpty);
    }

    // if (emptyMessage && cartContent) {
    //   if (cart.length > 0) {
    //     // Has items in cart
    //     emptyMessage.classList.add("hidden");
    //     cartContent.classList.remove("hidden");
    //   } else {
    //     // Cart is empty
    //     emptyMessage.classList.remove("hidden");
    //     cartContent.classList.add("hidden");
    //   }
    // }
  }

  // Update initialization to include handleEmptyCart
  document.addEventListener("DOMContentLoaded", () => {
    initializeQuantityControls();
    handleEmptyCart(); // Check cart state on page load
  });

  // Also handle empty cart state after item removal
  function updateCart() {
    console.log("Cart updated");
    handleEmptyCart();
  }
</script>
