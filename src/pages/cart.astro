---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Cart | VANGULAR";
const keywords = "Cart, Shopping Cart, Checkout";
---

<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <Header />
  <main>
    <section class="content-container">
      <div class="heading">
        <h3>Your Cart</h3>
      </div>

      <!-- <div class="cart-container">
        <div class="cart-list-container">
          <ul id="cart-items-list"></ul>
          <p id="cart-total-price">Total Amount: $0</p>
        </div>
      </div> -->

      <div class="cart-container">
        <div class="cart-products-grid">
          <div class="cart-titles">Product</div>
          <div class="cart-titles">Quantity</div>
          <div class="cart-titles">Total</div>
        </div>

        <div class="cart-products-grid">
          <!-- {categoryProducts.map((product) => (
          <a href={`/products/${product.slug}`}> -->

          <div class="cart-product-info">
            <div class="cart-product-image">
              <img
                src="/src/assets/images/web/logo.png"
                alt="Product Image"
                loading="lazy"
              />
              <!-- <img
              src={product.images?.[0] || "/src/assets/images/web/logo.png"}
              alt={product.name}
              loading="lazy"
            /> -->
            </div>

            <div class="cart-product-text">
              <p>Product Name</p>
              <p>$1 per item</p>
              <!-- <h4>{product.name}</h4> -->
            </div>
          </div>

          <div class="cart-product-quantity">
            <div class="quantity-controls">
              <button class="quantity-btn minus" aria-label="Decrease quantity"
                >-</button
              >

              <span class="quantity">1</span>
              <button class="quantity-btn plus" aria-label="Increase quantity"
                >+</button
              >
            </div>
            <button class="delete-btn" aria-label="Remove item">
              <i class="fa fa-trash"></i>
            </button>
            <!-- <p>1</p> -->
            <!-- <h4>{product.quantity}</h4> -->
          </div>

          <div class="cart-product-total-price">
            <p>$1 x Quantity</p>
            <!-- <h4>${product.price * product.quantity}</h4> -->
          </div>
        </div>

        <div class="cart-buttons">
          <a href="/merch" class="link">Continue Shopping</a>

          <a
            href="/checkout"
            class="button button-primary"
            id="proceed-to-payment"
          >
            Proceed to Checkout
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .cart-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: var(--spacing-xl);
  }

  .cart-products-grid {
    display: grid;
    grid-template-columns: 3fr 1fr 1fr;
    gap: var(--spacing-3xl);
    width: 100%;
    align-items: center;
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
    /* border-bottom: var(--border-secondary); */
    font-size: var(--font-size-base);
    /* margin: var(--spacing-md) 0; */
    /* padding: 0 var(--spacing-md); */
    border-bottom: var(--border-tertiary);
  }

  .cart-titles {
    display: grid;
    width: 100%;
    font-weight: bold;
    font-size: var(--font-size-sm);
  }

  .cart-product-info {
    display: flex;
    /* flex-direction: row; */
    align-items: center;
    gap: var(--spacing-xl);
    /* width: cart-container; */
  }

  .cart-product-image {
    /* width: 100px;  */
    width: 100px;
    height: 100px;
    flex-shrink: 0;
  }

  .cart-product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius-sm);
    border: var(--border-tertiary);
  }

  .cart-product-text {
    margin-left: var(--spacing-lg);
    /* text-align: right; */
    flex-grow: 1;
    text-align: left;
  }

  .cart-product-total-price {
    p {
      text-align: center;
    }
  }

  .cart-product-quantity {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    justify-content: center;
    text-align: center;

    p {
      text-align: center;
    }
  }

  .quantity-controls {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    border: var(--border-tertiary);
    border-radius: var(--border-radius-sm);
    padding: var(--spacing-xs);
    font-size: var(--font-size-base);
  }

  .quantity-btn {
    background: none;
    border: none;
    color: var(--color-text-primary);
    width: var(--font-size-lg);
    height: var(--font-size-lg);
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .quantity-btn:hover {
    color: var(--color-text-light);
    background-color: var(--color-button-primary);
    border-radius: var(--border-radius-circle);
  }

  .quantity {
    min-width: var(--font-size-lg);
    text-align: center;
    font-weight: bold;
  }

  .delete-btn {
    background: none;
    border: none;
    color: var(--color-error);
    cursor: pointer;
    transition: all var(--transition-normal);
    padding: var(--spacing-xs);
    font-size: var(--font-size-base);
  }
  /*
  .delete-btn:hover {
    transform: scale(1.1);
  } */

  .cart-buttons {
    display: flex;
    justify-content: space-between; /* Changed from flex-end to space-between */
    align-items: center;
    width: 100%;
    padding: 0 var(--spacing-md); /* Added padding to align with grid */
    /* margin-top: var(--spacing-xl);
    border-top: var(--border-tertiary); */

    .link {
      font-size: var(--font-size-base);

      padding: var(--spacing-sm) var(--spacing-md);
    }
  }

  /* Ensure consistent button sizes */
  .cart-buttons .button,
  .cart-buttons .link {
    min-width: 150px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .cart-products-grid,
    .cart-titles {
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--spacing-md);
    }

    .cart-product-image {
      width: 80px;
      height: 80px;
    }

    .cart-buttons {
      flex-direction: column-reverse;
      gap: var(--spacing-md);
    }

    .cart-buttons .button,
    .cart-buttons .link {
      width: 70%;
    }
  }
</style>

<script>
  function initializeQuantityControls() {
    document.querySelectorAll(".quantity-controls").forEach((control) => {
      const minusBtn = control.querySelector(".minus");
      const plusBtn = control.querySelector(".plus");
      const quantitySpan = control.querySelector(".quantity");

      minusBtn?.addEventListener("click", () => {
        let quantity = parseInt(quantitySpan?.textContent || "0");
        if (quantity > 1) {
          quantity--;
          if (quantitySpan) quantitySpan.textContent = quantity.toString();
          updateCartItem(quantity);
        }
      });

      plusBtn?.addEventListener("click", () => {
        let quantity = parseInt(quantitySpan?.textContent || "0");
        quantity++;
        if (quantitySpan) quantitySpan.textContent = quantity.toString();
        updateCartItem(quantity);
      });
    });

    document.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const cartItem = (e.target as HTMLElement).closest(
          ".cart-products-grid",
        );
        if (cartItem) {
          cartItem.remove();
          updateCart();
        }
      });
    });
  }

  function updateCartItem(quantity: number) {
    // Add your cart update logic here
    console.log("Updated quantity:", quantity);
    updateCart();
  }

  function updateCart() {
    // Add your cart total update logic here
    console.log("Cart updated");
  }

  // Initialize controls when the page loads
  document.addEventListener("DOMContentLoaded", initializeQuantityControls);
</script>
