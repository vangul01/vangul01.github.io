---
import BaseLayout from "../layouts/BaseLayout.astro";

import { getAllProducts, getOptimizedImageUrl } from "../lib/sanity-client";
import type { Product } from "../types/sanity-schema";

import logoFallback from "../assets/images/web/logo_eyewhites.png";

const products = await getAllProducts();

const pageTitle = "Merch | VANGULAR";
const keywords = "art, merchandise, prints, digital art, paintings";
---

<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <main>
    <section class="section">
      {
        products.length === 0 ? (
          <div class="container column flex-center">
            <h3>Check back soon for new merch!</h3>
          </div>
        ) : (
          <div class="container grid-4">
            {products.map((product) => (
              <a href={`/products/${product.slug}`}>
                <div>
                  <img
                    src={
                      product.images?.[0]
                        ? getOptimizedImageUrl(product.images[0], 400)
                        : logoFallback.src
                    }
                    alt={product.name}
                    loading="lazy"
                  />
                </div>

                <div>
                  <h4>{product.name}</h4>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
