---
import CheckoutHeader from "../components/CheckoutHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

import { initializeCheckout } from "../scripts/cart/checkout";

const pageTitle = "Checkout | VANGULAR";
const keywords = "checkout, stripe, payment";
---

<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <CheckoutHeader />

  <!-- <script src="https://js.stripe.com/v3/" defer crossorigin="anonymous" -->
  <!-- ></script> -->

  <main>
    <div id="checkout-loading">Preparing checkout...</div>
  </main>
</BaseLayout>

<script src="https://js.stripe.com/v3/" defer></script>
<script>
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const { loadCart } = await import("../scripts/cart/cart-storage.js");
      const cart = loadCart();

      const response = await fetch(
        "/.netlify/functions/create-checkout-session",
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items: cart }),
        },
      );

      const { sessionId } = await response.json();
      const stripePublicKey = import.meta.env.PUBLIC_STRIPE_KEY;
      console.log("Initializing checkout with key:", stripePublicKey);

      const stripe = Stripe(stripePublicKey); // Initialize Stripe with the public key
      await stripe.initializeCheckout({ sessionId });
    } catch (error) {
      console.error("Checkout initialization error:", error);
    }
  });
</script>
