---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Order Success | VANGULAR";
const keywords =
  "order success, payment success, thank you, order confirmation";
---

<!-- I'd like to have a success footer here which highlights connecting
 on social media and signing up to newsletter -->
<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <main>
    <div class="container column flex-center">
      <h3>Thank you!</h3>
      <h4>Your payment was successful :)</h4>
      <br /><br />
      <h5>
        We've sent a confirmation email to [customer email address] with all the
        details.
      </h5>
    </div>
    <a href="/home"
      ><button class="button button-primary" role="button"
        >Back to Vangular</button
      ></a
    >
  </main>
</BaseLayout>
<Footer />
