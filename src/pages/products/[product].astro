---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { client } from "../../lib/sanity-client";
import type { Product } from "../../types/sanity-schema";

export async function getStaticPaths() {
  const query = `*[_type == "product"]{
    _id,
    "slug": slug.current,
    name,
    description,
    materials,
    dimensions,
    quantity,
    stripePriceId,
    "images": images[].asset->url,
    category,
    featured
  }`;

  const products = (await client.fetch(query)) as Product[];

  return products.map((product: Product) => ({
    params: { product: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const pageTitle = `${product.name} | VANGULAR`;
const keywords = `vangular, ${product.name}, art, products`;
---

<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <Header />
  <main>
    <section class="content-container" id="product-page">
      <div class="two-column-container">
        <div class="image product-image">
          <div class="zoom-container">
            <img
              id="main-product-image"
              src={product.images?.[0] || "/src/assets/images/web/logo.png"}
              alt={product.name}
              loading="eager"
            />
          </div>

          {
            product.images?.length > 1 && (
              <div class="product-thumbnails" role="list">
                {product.images.map((imageUrl, index) => (
                  <img
                    src={imageUrl}
                    alt={`${product.name} view ${index + 1}`}
                    class={`thumbnail ${index === 0 ? "active" : ""}`}
                    data-image-url={imageUrl}
                    data-index={index}
                    loading="lazy"
                  />
                ))}
              </div>
            )
          }
        </div>

        <div class="text product-text">
          <h3>{product.name}</h3>

          {product.quantity === 0 && <h3>*Currently unavailable*</h3>}

          <div>
            <p>$GET FROM STRIPE USD</p>
            <p>{product.quantity} Available</p>
          </div>

          {
            product.quantity > 0 && (
              <button
                class="button button-primary"
                id="add-to-cart"
                data-price-id={product.stripePriceId}
                data-name={product.name}
                data-price="GET FROM STRIPE"
                data-quantity="1"
              >
                Add to Cart
              </button>
            )
          }

          <div>
            <p>{product.description}</p>
            <h4>Details</h4>
            {product.materials && <p>Materials: {product.materials}</p>}
            {product.dimensions && <p>Dimensions: {product.dimensions}</p>}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector(".zoom-container");
    const image = document.getElementById("main-product-image");

    if (container && image) {
      container.addEventListener("mousemove", (e) => {
        const bounds = container.getBoundingClientRect();

        // Calculate mouse position as percentages
        const x = ((e as MouseEvent).clientX - bounds.left) / bounds.width;
        const y = ((e as MouseEvent).clientY - bounds.top) / bounds.height;

        // Update image position
        image.style.transformOrigin = `${x * 100}% ${y * 100}%`;
        image.style.transform = "scale(2)";
      });

      container.addEventListener("mouseleave", () => {
        image.style.transformOrigin = "center center";
        image.style.transform = "scale(1)";
      });
    }

    const mainImage = document.getElementById(
      "main-product-image",
    ) as HTMLImageElement;
    const thumbnails = document.querySelectorAll(".thumbnail");

    // Set first thumbnail as active by default
    thumbnails[0]?.classList.add("active");

    thumbnails.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        // Update main image with fade effect
        mainImage.style.opacity = "0";
        const newImageUrl = thumb.getAttribute("data-image-url");

        if (newImageUrl && mainImage) {
          setTimeout(() => {
            mainImage.src = newImageUrl;
            mainImage.style.opacity = "1";
          }, 200);
        }

        // Update active thumbnail state
        thumbnails.forEach((t) => t.classList.remove("active"));
        thumb.classList.add("active");
      });
    });

    // Optional: Keyboard navigation
    document.addEventListener("keydown", (e) => {
      const active = document.querySelector(".thumbnail.active") as HTMLElement;
      if (!active) return;

      const currentIndex = parseInt(active.getAttribute("data-index") || "0");
      let nextIndex;

      if (e.key === "ArrowLeft") {
        nextIndex = currentIndex - 1;
      } else if (e.key === "ArrowRight") {
        nextIndex = currentIndex + 1;
      } else {
        return;
      }

      const nextThumb = document.querySelector(
        `[data-index="${nextIndex}"]`,
      ) as HTMLElement;
      if (nextThumb) nextThumb.click();
    });
  });
</script>

<style>
  .product-image {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    width: 100%;
  }

  .zoom-container {
    overflow: hidden;
    position: relative;
    width: 100%;
    height: 500px; /* Set a fixed height or adjust as needed */
    cursor: zoom-in;
    border-radius: var(--border-radius-sm);
  } /* margin-top: 0; */

  #main-product-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition:
      transform 0.1s ease-out,
      opacity 0.2s ease;
  }

  .product-thumbnails {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .thumbnail {
    width: 80px;
    height: 80px;
    object-fit: cover;
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: var(--border-radius-sm);
    transition: border-color 0.2s ease;
  }

  .thumbnail:hover {
    border-color: var(--color-border);
  }

  .thumbnail.active {
    border-color: var(--color-accent);
  }
</style>
