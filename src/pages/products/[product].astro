---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

import { getStripePrice } from "../../lib/stripe-client";
import { client } from "../../lib/sanity-client";
import type { Product } from "../../types/sanity-schema";

export async function getStaticPaths() {
  const query = `*[_type == "product"]{
    _id,
    "slug": slug.current,
    name,
    description,
    materials,
    dimensions,
    quantity,
    stripePriceId,
    "images": images[].asset->url,
    category,
    featured
  }`;

  const products = (await client.fetch(query)) as Product[];

  return products.map((product: Product) => ({
    params: { product: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const pageTitle = `${product.name} | VANGULAR`;
const keywords = `vangular, ${product.name}, art, products`;
---

<BaseLayout pageTitle={pageTitle} keywords={keywords}>
  <Header />
  <main>
    <section class="content-container" id="product-page">
      <div class="two-column-container">
        <div class="image product-image">
          <div class="zoom-container">
            <img
              id="main-product-image"
              src={product.images?.[0] || "/src/assets/images/web/logo.png"}
              alt={product.name}
              loading="eager"
            />
          </div>

          {
            product.images?.length > 1 && (
              <div class="product-thumbnails" role="list">
                {product.images.map((imageUrl, index) => (
                  <img
                    src={imageUrl}
                    alt={`${product.name} view ${index + 1}`}
                    class={`thumbnail ${index === 0 ? "active" : ""}`}
                    data-image-url={imageUrl}
                    data-index={index}
                    loading="lazy"
                  />
                ))}
              </div>
            )
          }
        </div>

        <div class="text product-text">
          <h3>{product.name}</h3>

          {product.quantity === 0 && <h3>*Currently unavailable*</h3>}

          <div>
            <p id="product-price" data-price-id={product.stripePriceId}>
              Loading price...
            </p>
            <p>{product.quantity} Available</p>
          </div>

          {
            product.quantity > 0 && (
              <button
                class="button button-primary"
                id="add-to-cart"
                data-price-id={product.stripePriceId}
                data-name={product.name}
                data-image={product.images?.[0]}
                data-quantity="1"
                data-product-url={`${product.slug}`}
              >
                Add to Cart
              </button>
            )
          }

          <div>
            <p>{product.description}</p>
            <h4>Details</h4>
            {product.materials && <p>Materials: {product.materials}</p>}
            {product.dimensions && <p>Dimensions: {product.dimensions}</p>}
          </div>
        </div>
      </div>
      <div>
        <a href="#" class="link" onclick="window.history.back()">
          Go Back
        </a>
        <br>
        <a href="/cart" class="link">
          Go To Cart
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { initZoom, initThumbnails, initKeyboardNav } from "../../scripts/product.js";
  document.addEventListener("DOMContentLoaded", () => {
    initZoom();
    initThumbnails();
    initKeyboardNav();
  });

    import { getStripePrice } from "../../lib/stripe-client";

  async function loadPrice() {
    const priceElement = document.getElementById('product-price');
    const priceId = priceElement?.dataset.priceId;
    
    if (priceId) {
      try {
        const price = await getStripePrice(priceId);
        priceElement.textContent = `$${price.amount} ${price.currency.toUpperCase()}`;
        
        // Update the add-to-cart button's price data
        const addToCartBtn = document.getElementById('add-to-cart');
        if (addToCartBtn) {
          addToCartBtn.dataset.price = String(price.amount);
        }
      } catch (error) {
        console.error('Error loading price:', error);
        priceElement.textContent = 'Price unavailable';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadPrice();
    // ...your existing initialization code...
    initZoom();
    initThumbnails();
    initKeyboardNav();
  });
</script>
